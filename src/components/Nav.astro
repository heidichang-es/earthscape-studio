---
type NavKey = 'index' | 'works' | 'journal' | 'visit' | 'about';

interface Props {
  active?: NavKey;
}

const { active } = Astro.props;

const items: Array<{ key: NavKey; label: string; href: string }> = [
  { key: 'index', label: 'Index', href: '/' },
  { key: 'visit', label: 'Visit', href: '/visit' },
  { key: 'about', label: 'About', href: '/about' },
  // Works + Journal hidden until real content lands. Re-enable in nav once
  // the catalog has real photographs and the journal has authored entries.
];
---

<nav class="nav">
  <div class="nav-inner">
    <div class="nav-brand"><strong>ES</strong><span class="brand-full"> · earthscape-studio.com</span></div>
    <div class="nav-center">埴 角</div>
    <div class="nav-menu">
      {items.map(({ key, label, href }) => (
        <a href={href} style={active === key ? 'color: var(--fe-500);' : undefined}>{label}</a>
      ))}
    </div>
  </div>
</nav>
