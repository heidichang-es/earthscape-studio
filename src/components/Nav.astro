---
type NavKey = 'index' | 'works' | 'journal' | 'visit' | 'about';

interface Props {
  active?: NavKey;
}

const { active } = Astro.props;

const items: Array<{ key: NavKey; label: string; href: string }> = [
  { key: 'index',   label: 'Index',   href: '/' },
  { key: 'journal', label: 'Journal', href: '/journal' },
  { key: 'visit',   label: 'Visit',   href: '/visit' },
  { key: 'about',   label: 'About',   href: '/about' },
  // Works hidden until the catalog has real photographs.
];
---

<nav class="nav">
  <div class="nav-inner">
    <div class="nav-brand"><a href="/"><strong>ES</strong><span class="brand-full"> · earthscape-studio.com</span></a></div>
    <div class="nav-center"><a href="/">埴 角</a></div>
    <div class="nav-menu">
      {items.map(({ key, label, href }) => (
        <a href={href} style={active === key ? 'color: var(--fe-500);' : undefined}>{label}</a>
      ))}
    </div>
  </div>
</nav>
