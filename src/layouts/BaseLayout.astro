---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

type NavKey = 'index' | 'works' | 'journal' | 'visit' | 'about';

interface Props {
  title: string;
  description?: string;
  active?: NavKey;
  lang?: string;
  /** Set true to keep the page out of search indexes and the sitemap-feeder meta. */
  noindex?: boolean;
}

const {
  title,
  description = 'A peninsula of earth — ceramic vessels made from kaolin, feldspar, quartz, iron oxide and wood ash.',
  active,
  lang = 'zh-TW',
  noindex = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,500;1,8..60,300;1,8..60,400&family=Noto+Serif+TC:wght@300;400;500;600&family=JetBrains+Mono:wght@300;400;500&display=swap"
    />
    <slot name="head" />
  </head>
  <body>
    <div class="grain"></div>

    <slot name="top" />

    <Nav active={active} />

    <slot />

    <Footer />
  </body>
</html>
