---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArchiveHead from '../components/ArchiveHead.astro';
import Tag from '../components/Tag.astro';

const recentEntries = (await getCollection('journal'))
  .filter((e) => !e.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);

const fmt = (d: Date) =>
  `${d.getUTCFullYear()} · ${String(d.getUTCMonth() + 1).padStart(2, '0')} · ${String(d.getUTCDate()).padStart(2, '0')}`;
---

<BaseLayout
  title="Earthscape · 埴角 | Studio Archive"
  description="A peninsula of earth — ceramic objects made from kaolin, feldspar, quartz, iron oxide ... | 埴角 — 用黏土填補建構的新生岬角。"
  active="index"
>
  <ArchiveHead slot="top" updated="05 · 26 · 2026" />

  <!-- COVER · museum acquisition card -->
  <section class="cover" id="cover">
    <div class="cover-left">
      <span class="label-strong">Accession Card · 檔案卡</span>

      <dl class="cover-cat">
        <dt>Catalog No.</dt>
        <dd>ES · ARC · 2026</dd>

        <dt>Type</dt>
        <dd>Ceramic studio archive</dd>

        <dt>Origin</dt>
        <dd>Taipei, Taiwan</dd>

        <dt>Established</dt>
        <dd>2026 · Spring</dd>

        <dt>Medium</dt>
        <dd>Stoneware, glaze, fire</dd>

        <dt>Active Series</dt>
        <dd>Cape · 01</dd>

        <dt>Holdings</dt>
        <dd>64 pieces (planned)</dd>
      </dl>
    </div>

    <div class="cover-right">
      <h1 class="cover-title"><em>Earth</em>scape</h1>
      <div class="cover-zh">埴 角</div>

      <p class="cover-statement">
        A peninsula of earth — still attached to the mainland, but already reaching into another sea.
      </p>

      <p class="cover-statement-zh">
        有一塊地正在從我身上伸出去——<br />
        在每日通勤的辦公室與每個週末沾滿土的雙手之間，<br />
        仍然連著本土，但已經探進另一片水域。
      </p>
    </div>
  </section>

  <!-- ETYMOLOGY · § 01 -->
  <section class="etymology">
    <span class="label-strong">§ 01<br />Etymology<br />字源</span>

    <div class="etym-rows">
      <div class="etym-row">
        <div class="etym-term">
          earthscape
          <span class="ipa">/ˈɜːrθskeɪp/ · n.</span>
        </div>
        <div class="etym-def">
          <em>地景</em>。從土壤的紋理、地層的橫切，到一整片風景的延展。
        </div>
      </div>

      <div class="etym-row">
        <div class="etym-term">
          earth scape
          <span class="ipa">/ɜːrθ · skeɪp/ · n.</span>
        </div>
        <div class="etym-def">
          <em>紋理</em>。以土為載體，用火焰將時間燒結紀錄。
        </div>
      </div>

      <div class="etym-row">
        <div class="etym-term">
          earth's cape
          <span class="ipa">/ɜːrθs keɪp/ · n.</span>
        </div>
        <div class="etym-def">
          <em>岬角</em>。岬角是陸地望向大海的延伸，是邊界，也是探索。一個身份在本土與遠方之間的位置。
        </div>
      </div>

      <div class="etym-row">
        <div class="etym-term">
          escape
          <span class="ipa">/ɪˈskeɪp/ · v.</span>
        </div>
        <div class="etym-def">
          <em>出走</em>。在僵化前從日常工作脫逃，從鍵盤與螢幕抽身，自一個身份走向另一個身份的縫隙。
        </div>
      </div>

      <div class="etym-row">
        <div class="etym-term">
          埴角
          <span class="ipa">zhí · jiǎo · n.</span>
        </div>
        <div class="etym-def">
          「埴」者，黏土也——《尚書·禹貢》「陶人埏埴而為器」，《道德經》「埏埴以為器」。「角」即海岬。從大陸從日常向更廣闊的世界探索與延伸。
        </div>
      </div>
    </div>
  </section>

  <!-- MATERIALS · § 02 -->
  <section class="materials" id="materials">
    <div class="materials-head">
      <h2><em>Materials</em> · 基本素材</h2>
      <span class="label">§ 02 · CORE MATERIALS</span>
    </div>

    <div class="materials-grid">
      <article class="material">
        <div class="material-swatch"><div class="swatch-fill" style="background:linear-gradient(90deg,#F7F1E6 0%,#E8DFCE 100%)"></div></div>
        <div class="material-num">MAT · 001</div>
        <div class="material-formula">Al₂Si₂O₅(OH)₄</div>
        <div class="material-name-en"><em>Kaolinite</em></div>
        <div class="material-name-zh">高 嶺 土</div>
        <p class="material-desc">來自景德鎮高嶺村的白色黏土。1200°C 之後，它從泥變成石。一個名字裡藏著一座山。</p>
      </article>

      <article class="material">
        <div class="material-swatch"><div class="swatch-fill" style="background:linear-gradient(90deg,#EDE4D0 0%,#C9B896 100%)"></div></div>
        <div class="material-num">MAT · 002</div>
        <div class="material-formula">KAlSi₃O₈</div>
        <div class="material-name-en"><em>Feldspar</em></div>
        <div class="material-name-zh">長 石</div>
        <p class="material-desc">地殼裡最常見的礦物。在陶藝中是助熔劑——沒有它，土只是土；有了它，土會發光。</p>
      </article>

      <article class="material">
        <div class="material-swatch"><div class="swatch-fill" style="background:linear-gradient(90deg,#F0EBE0 0%,#D6CFC0 100%)"></div></div>
        <div class="material-num">MAT · 003</div>
        <div class="material-formula">SiO₂</div>
        <div class="material-name-en"><em>Quartz</em></div>
        <div class="material-name-zh">石 英</div>
        <p class="material-desc">沙、玻璃、水晶——它們在最深處是同一種東西。在土裡，它是骨架，給予結構與強度。</p>
      </article>

      <article class="material">
        <div class="material-swatch"><div class="swatch-fill" style="background:linear-gradient(90deg,#E8A87C 0%,#A8421C 50%,#3D2820 100%)"></div></div>
        <div class="material-num">MAT · 004</div>
        <div class="material-formula">Fe₂O₃ · Fe₃O₄</div>
        <div class="material-name-en"><em>Iron Oxide</em></div>
        <div class="material-name-zh">氧 化 鐵</div>
        <p class="material-desc">黃 · 紅 · 黑。同一個元素三種面貌。所有「土的顏色」，都是它的顏色。</p>
      </article>
    </div>
  </section>

  <!-- SERIES · § 03 -->
  <section class="series" id="series">
    <div class="materials-head">
      <h2><em>Series</em> · 系列</h2>
      <span class="label">§ 03 · Production Catalog</span>
    </div>

    <article class="series-card">
      <div class="series-meta">
        <div class="series-num">CAPE · 01</div>
        <h3 class="series-title"><em>儲物</em><br />Gathering The Food</h3>
        <div class="series-date">2026 · Autumn</div>
        <div class="series-status">In Progress</div>
      </div>

      <div class="series-body">
        <p class="series-desc">
          Earthscape 的第一個系列。八個大型花器作為地景的主峰，圍繞著中型花器與生活器物——杯、缽、罐、擺件。從一塊土開始，到 64 件作品的完整地景。
        </p>

        <div class="series-inventory">
          <div class="inv-item">
            <div class="inv-count">8</div>
            <div class="inv-label">Large</div>
          </div>
          <div class="inv-item">
            <div class="inv-count">16</div>
            <div class="inv-label">Mid</div>
          </div>
          <div class="inv-item">
            <div class="inv-count">8</div>
            <div class="inv-label">Cup</div>
          </div>
          <div class="inv-item">
            <div class="inv-count">8</div>
            <div class="inv-label">Bowl</div>
          </div>
          <div class="inv-item">
            <div class="inv-count">8</div>
            <div class="inv-label">Jar</div>
          </div>
          <div class="inv-item">
            <div class="inv-count">8</div>
            <div class="inv-label">Object</div>
          </div>
          <div class="inv-item">
            <div class="inv-count">8</div>
            <div class="inv-label">Undefined</div>
          </div>
        </div>

        <div class="series-actions">
          <span class="label">56 pieces · 14 weeks · Catalog forthcoming</span>
        </div>
      </div>
    </article>
  </section>

  <!-- JOURNAL LATEST -->
  {recentEntries.length > 0 && (
    <section class="journal-latest" id="journal">
      <div class="journal-head">
        <h2><em>Journal</em> · 工作日誌</h2>
        <a href="/journal">All Entries →</a>
      </div>

      <div class="journal-list" data-count={recentEntries.length}>
        {recentEntries.map((entry) => (
          <a href={`/journal/${entry.id}`} class="journal-entry">
            <div class="journal-meta">
              <div class="journal-date">{fmt(entry.data.date)}</div>
              <div class="journal-tags">
                {entry.data.tags.map((t) => <Tag>{t}</Tag>)}
              </div>
            </div>
            <div class="journal-body">
              <h3 class="journal-title">{entry.data.title}</h3>
              <p class="journal-excerpt">{entry.data.excerpt}</p>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- VISIT CTA -->
  <section class="visit-cta" id="visit">
    <div class="visit-mark">§ 05 · Visit the Studio</div>
    <h2 class="visit-title">A short escape,<br />by appointment.</h2>
    <p class="visit-sub">Coming Soon</p>
    <a href="/visit" class="btn-cta">Book a Visit →</a>
  </section>
</BaseLayout>

<style>
  /* ── Hero / Cover ── */
  .cover {
    max-width: var(--content-wide);
    margin: 0 auto;
    padding: var(--s-16) var(--gutter) var(--s-12);
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--s-16);
    border-bottom: var(--hair);
  }

  .cover-left { padding-top: var(--s-3); }

  .cover-left :global(.label-strong) {
    display: block;
    margin-bottom: var(--s-3);
  }

  .cover-cat {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    line-height: 2;
    color: var(--mn-700);
    border-top: var(--hair);
    padding-top: var(--s-3);
    margin-top: var(--s-4);
  }

  .cover-cat dt {
    color: var(--mn-500);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-size: 0.65rem;
    margin-top: var(--s-2);
  }

  .cover-cat dd {
    color: var(--mn-900);
    margin-bottom: var(--s-2);
  }

  .cover-right { position: relative; }

  .cover-title {
    font-family: var(--font-display);
    font-size: clamp(3rem, 9vw, var(--t-display));
    font-weight: 300;
    line-height: 0.95;
    letter-spacing: -0.025em;
    color: var(--fe-500);
    margin-bottom: var(--s-3);
  }

  .cover-title em {
    font-style: italic;
    font-weight: 400;
    color: var(--fe-700);
  }

  .cover-zh {
    font-family: var(--font-zh);
    font-size: var(--t-2xl);
    font-weight: 300;
    letter-spacing: 0.5em;
    color: var(--mn-900);
    padding-left: 0.5em;
    margin-bottom: var(--s-8);
  }

  .cover-statement {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--t-xl);
    line-height: 1.55;
    color: var(--mn-700);
    max-width: 620px;
    border-left: var(--hair-accent);
    padding-left: var(--s-6);
    margin-bottom: var(--s-8);
  }

  .cover-statement-zh {
    font-family: var(--font-zh);
    font-size: var(--t-base);
    line-height: 2;
    color: var(--mn-700);
    max-width: 620px;
    padding-left: var(--s-6);
  }

  @media (max-width: 880px) {
    .cover {
      grid-template-columns: 1fr;
      gap: var(--s-8);
      padding: var(--s-8) var(--gutter);
    }
    .cover-zh { font-size: var(--t-xl); letter-spacing: 0.3em; }
  }

  /* ── Etymology ── */
  .etymology {
    max-width: var(--content-wide);
    margin: 0 auto;
    padding: var(--s-16) var(--gutter);
    border-bottom: var(--hair);
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--s-12);
  }

  .etymology :global(.label-strong) {
    align-self: start;
  }

  .etym-rows { display: grid; gap: var(--s-6); }

  .etym-row {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: var(--s-6);
    padding-bottom: var(--s-6);
    border-bottom: var(--hair);
  }

  .etym-row:last-child { border-bottom: none; padding-bottom: 0; }

  .etym-term {
    font-family: var(--font-display);
    font-size: var(--t-2xl);
    font-weight: 300;
    color: var(--fe-500);
    letter-spacing: -0.005em;
  }

  .etym-term .ipa {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--mn-500);
    letter-spacing: 0.05em;
    margin-top: var(--s-1);
  }

  .etym-def {
    font-family: var(--font-zh);
    font-size: var(--t-base);
    line-height: 1.85;
    color: var(--mn-900);
    align-content: center;
  }

  .etym-def em {
    color: var(--accent-500);
    font-style: italic;
    font-family: var(--font-display);
  }

  @media (max-width: 880px) {
    .etymology { grid-template-columns: 1fr; gap: var(--s-6); }
    .etym-row { grid-template-columns: 1fr; gap: var(--s-2); }
    .etym-term { font-size: var(--t-xl); }
  }

  /* ── Materials ── */
  .materials {
    max-width: var(--content-wide);
    margin: 0 auto;
    padding: var(--s-16) var(--gutter);
    border-bottom: var(--hair);
  }

  .materials-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--s-8);
    padding-bottom: var(--s-3);
    border-bottom: var(--hair);
  }

  .materials-head h2 {
    font-family: var(--font-display);
    font-size: var(--t-3xl);
    font-weight: 400;
    color: var(--mn-900);
    letter-spacing: -0.01em;
  }

  .materials-head h2 em { font-style: italic; color: var(--fe-500); }

  .materials-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-left: var(--hair);
  }

  .material {
    padding: var(--s-6);
    border-right: var(--hair);
    border-bottom: var(--hair);
    border-top: var(--hair);
    background: var(--bg-elev);
    transition: background 0.3s;
    position: relative;
    min-height: 280px;
    display: flex;
    flex-direction: column;
  }

  .material:hover { background: var(--bg-sunken); }

  .material-num {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    color: var(--mn-500);
    margin-bottom: var(--s-3);
  }

  .material-formula {
    font-family: var(--font-mono);
    font-size: var(--t-xl);
    color: var(--fe-500);
    letter-spacing: 0.02em;
    margin-bottom: var(--s-1);
    font-weight: 500;
  }

  .material-formula sub {
    font-size: 0.65em;
    vertical-align: baseline;
    position: relative;
    bottom: -0.2em;
  }

  .material-name-en {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--t-base);
    color: var(--mn-700);
    margin-bottom: var(--s-1);
  }

  .material-name-zh {
    font-family: var(--font-zh);
    font-size: var(--t-base);
    color: var(--mn-900);
    margin-bottom: var(--s-4);
    letter-spacing: 0.05em;
  }

  .material-desc {
    font-family: var(--font-zh);
    font-size: var(--t-sm);
    line-height: 1.7;
    color: var(--mn-700);
    margin-top: auto;
  }

  .material-swatch {
    width: 100%;
    height: 6px;
    margin-bottom: var(--s-4);
    background: var(--bg-sunken);
    position: relative;
    overflow: hidden;
  }

  .swatch-fill {
    position: absolute;
    inset: 0;
    width: 100%;
  }

  @media (max-width: 1100px) {
    .materials-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .materials-grid { grid-template-columns: 1fr; }
  }

  /* ── Series ── */
  .series {
    max-width: var(--content-wide);
    margin: 0 auto;
    padding: var(--s-16) var(--gutter);
    border-bottom: var(--hair);
  }

  .series-card {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: var(--s-12);
    padding: var(--s-8) 0;
    border-bottom: var(--hair);
    align-items: start;
  }

  .series-card:last-child { border-bottom: none; }

  .series-meta {
    border-left: 2px solid var(--fe-500);
    padding-left: var(--s-6);
  }

  .series-num {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.3em;
    color: var(--fe-500);
    margin-bottom: var(--s-2);
  }

  .series-title {
    font-family: var(--font-display);
    font-size: var(--t-3xl);
    font-weight: 300;
    color: var(--mn-900);
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin-bottom: var(--s-2);
  }

  .series-title em { font-style: italic; color: var(--fe-500); }

  .series-date {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    color: var(--mn-500);
    letter-spacing: 0.1em;
  }

  .series-status {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 4px 10px;
    border: 1px solid var(--accent-500);
    background-color: var(--accent-500);
    color: var(--bg);
    margin-top: var(--s-3);
  }

  .series-body { padding-top: var(--s-1); }

  .series-desc {
    font-family: var(--font-zh);
    font-size: var(--t-base);
    line-height: 1.85;
    color: var(--mn-900);
    margin-bottom: var(--s-6);
    max-width: 60ch;
  }

  .series-inventory {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: var(--hair);
    border-left: var(--hair);
  }

  .inv-item {
    padding: var(--s-3);
    border-right: var(--hair);
    border-bottom: var(--hair);
    background: var(--bg-elev);
    text-align: center;
  }

  .inv-count {
    font-family: var(--font-display);
    font-size: var(--t-2xl);
    color: var(--fe-500);
    font-weight: 300;
    line-height: 1;
    margin-bottom: 4px;
  }

  .inv-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--mn-500);
  }

  .series-actions {
    margin-top: var(--s-6);
    display: flex;
    gap: var(--s-4);
    align-items: center;
  }

  @media (max-width: 880px) {
    .series-card { grid-template-columns: 1fr; gap: var(--s-6); }
    .series-inventory { grid-template-columns: repeat(3, 1fr); }
  }

  /* ── Journal latest ── */
  .journal-latest {
    max-width: var(--content-wide);
    margin: 0 auto;
    padding: var(--s-16) var(--gutter);
    border-bottom: var(--hair);
  }

  .journal-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: var(--s-8);
    padding-bottom: var(--s-3);
    border-bottom: var(--hair);
  }

  .journal-head h2 {
    font-family: var(--font-display);
    font-size: var(--t-3xl);
    font-weight: 400;
    color: var(--mn-900);
  }

  .journal-head h2 em { font-style: italic; color: var(--fe-500); }

  .journal-head a {
    font-family: var(--font-mono);
    font-size: var(--t-xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--mn-700);
    border-bottom: 1px solid var(--fe-500);
    padding-bottom: 2px;
  }

  /* Default: 3-card grid (when there are 3 entries) */
  .journal-list {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-left: var(--hair);
  }

  .journal-list[data-count="2"] { grid-template-columns: repeat(2, 1fr); }
  .journal-list[data-count="1"] { grid-template-columns: 1fr; }

  /* Base card */
  .journal-entry {
    padding: var(--s-6);
    border-right: var(--hair);
    border-bottom: var(--hair);
    border-top: var(--hair);
    background: var(--bg-elev);
    transition: background 0.3s;
